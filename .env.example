# Copy this file to `.env` and fill in real keys. `.env` is gitignored.
# any-llm reads provider keys from the environment.

OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# If you prefer a single key via OpenRouter (optional alternative):
# OPENROUTER_API_KEY=

# Literature discovery (Semantic Scholar key is optional; Crossref mailto is recommended):
# SEMANTIC_SCHOLAR_API_KEY=
# CROSSREF_MAILTO=researcher@example.org
